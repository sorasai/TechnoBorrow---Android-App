<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".features.dashboard.ui.RequestDetailsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/dark_red">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request Details"
                android:textColor="@color/dark_red"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Item Main Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/ivItemImageDet"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:background="#F3F4F6"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_plus"
                        app:tint="#D1D5DB" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tvItemNameDet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/tvStatusDet"
                                android:text="Modern DSLR Camera"
                                android:textColor="#111827"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvStatusDet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="#FEF3C7"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="POSTED"
                                android:textColor="#B45309"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Stepper UI -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layoutStepper"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="24dp">

                            <!-- Progress Background Line -->
                            <View
                                android:id="@+id/lineProgress"
                                android:layout_width="0dp"
                                android:layout_height="4dp"
                                android:background="#E5E7EB"
                                app:layout_constraintStart_toStartOf="@+id/step1_circle"
                                app:layout_constraintEnd_toEndOf="@+id/step4_circle"
                                app:layout_constraintTop_toTopOf="@+id/step1_circle"
                                app:layout_constraintBottom_toBottomOf="@+id/step1_circle" />

                            <!-- Step 1: POSTED -->
                            <TextView
                                android:id="@+id/step1_circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_circle_inactive"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="#9CA3AF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintHorizontal_chainStyle="spread_inside"
                                app:layout_constraintEnd_toStartOf="@+id/step2_circle" />

                            <TextView
                                android:id="@+id/step1_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="POSTED"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toBottomOf="@+id/step1_circle"
                                app:layout_constraintStart_toStartOf="@+id/step1_circle"
                                app:layout_constraintEnd_toEndOf="@+id/step1_circle" />

                            <!-- Step 2: MATCHED -->
                            <TextView
                                android:id="@+id/step2_circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_circle_inactive"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="#9CA3AF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/step1_circle"
                                app:layout_constraintEnd_toStartOf="@+id/step3_circle" />

                            <TextView
                                android:id="@+id/step2_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="MATCHED"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toBottomOf="@+id/step2_circle"
                                app:layout_constraintStart_toStartOf="@+id/step2_circle"
                                app:layout_constraintEnd_toEndOf="@+id/step2_circle" />

                            <!-- Step 3: BORROWED -->
                            <TextView
                                android:id="@+id/step3_circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_circle_inactive"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="#9CA3AF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/step2_circle"
                                app:layout_constraintEnd_toStartOf="@+id/step4_circle" />

                            <TextView
                                android:id="@+id/step3_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="BORROWED"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toBottomOf="@+id/step3_circle"
                                app:layout_constraintStart_toStartOf="@+id/step3_circle"
                                app:layout_constraintEnd_toEndOf="@+id/step3_circle" />

                            <!-- Step 4: RETURNED -->
                            <TextView
                                android:id="@+id/step4_circle"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_circle_inactive"
                                android:gravity="center"
                                android:text="4"
                                android:textColor="#9CA3AF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/step3_circle"
                                app:layout_constraintEnd_toEndOf="parent" />

                            <TextView
                                android:id="@+id/step4_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="RETURNED"
                                android:textColor="#9CA3AF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                app:layout_constraintTop_toBottomOf="@+id/step4_circle"
                                app:layout_constraintStart_toStartOf="@+id/step4_circle"
                                app:layout_constraintEnd_toEndOf="@+id/step4_circle" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <TextView

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Description"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvDescriptionDet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="Detailed description comes here. I need this for my photography project this weekend."
                            android:textColor="#4B5563"
                            android:textSize="15sp"
                            android:lineSpacingExtra="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Purpose"
                            android:textColor="#374151"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvPurposeDet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Photography project"
                            android:textColor="#4B5563"
                            android:textSize="15sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Schedule Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Borrowing Schedule"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="From"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF"/>
                            <TextView
                                android:id="@+id/tvScheduleStartDet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2024-04-20 08:00"
                                android:textColor="#111827"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginHorizontal="16dp"
                            android:src="@drawable/ic_arrow_back"
                            android:rotation="180"
                            app:tint="#D1D5DB"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Until"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF"/>
                            <TextView
                                android:id="@+id/tvScheduleEndDet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2024-04-20 18:00"
                                android:textColor="#111827"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Requester Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivRequesterAvatarDet"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="#F3F4F6"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher"
                        app:shapeAppearanceOverlay="@style/CircleImage" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@+id/ivRequesterAvatarDet"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRequesterNameDet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textColor="#111827"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TechnoBorrow Community Member"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Offers Received Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvOffersSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Offers Received"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOffers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvNoOffersYet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No offers yet"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone" />


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOfferToLend"
                style="@style/AuthButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Offer to Lend"
                android:visibility="gone"
                android:textColor="@color/white"
                app:backgroundTint="@color/dark_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmBorrow"
                style="@style/AuthButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Borrow Receipt"
                android:visibility="gone"
                android:textColor="@color/white"
                app:backgroundTint="@color/dark_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmReturn"
                style="@style/AuthButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Return"
                android:visibility="gone"
                android:textColor="@color/white"
                app:backgroundTint="@color/dark_red" />

            <TextView
                android:id="@+id/tvReturnStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:text="Waiting for other user to confirm return..." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContactLender"
                style="@style/AuthButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contact Requester"
                android:textColor="@color/white"
                app:backgroundTint="@color/dark_red" />


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
