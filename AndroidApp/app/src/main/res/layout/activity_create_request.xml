<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".features.dashboard.ui.CreateRequestActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/dark_red">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Request"
                android:textColor="@color/dark_red"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Item Information"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Item Name"
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etItemName"
                        style="@style/FormInputStyle"
                        android:layout_marginBottom="16dp"
                        android:hint="What do you want to borrow?"
                        android:inputType="text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Description"
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etDescription"
                        style="@style/FormInputStyle"
                        android:layout_marginBottom="16dp"
                        android:gravity="top"
                        android:hint="Describe the item or your message to the lender"
                        android:inputType="textMultiLine"
                        android:minLines="3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Purpose"
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etPurpose"
                        style="@style/FormInputStyle"
                        android:layout_marginBottom="24dp"
                        android:hint="Why are you borrowing this?"
                        android:inputType="text" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="24dp"
                        android:background="#F3F4F6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Schedule"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start Date &amp; Time"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvStartDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="12dp"
                                android:text="Select Start"
                                android:background="@drawable/form_input_bg"
                                android:textSize="13sp"
                                android:textColor="#111827"/>
                        </LinearLayout>

                        <View android:layout_width="12dp" android:layout_height="1dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="End Date &amp; Time"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvEndDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="12dp"
                                android:text="Select End"
                                android:background="@drawable/form_input_bg"
                                android:textSize="13sp"
                                android:textColor="#111827"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="Total Duration: --"
                        android:textColor="#7A1E2D"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Item Image (Optional)"
                        android:textColor="#4B5563"
                        android:textSize="13sp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivItemPreview"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F3F4F6"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_plus"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:contentPadding="40dp"
                        app:tint="#9CA3AF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitRequest"
                        style="@style/AuthButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Post Request"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/dark_red" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
