<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0.5dp"
    app:cardBackgroundColor="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOfferLenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lender Name"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOfferMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I can lend this item."
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptOffer"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accept"
            android:textColor="@color/dark_red"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAcceptedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Accepted"
            android:textColor="#10B981"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
